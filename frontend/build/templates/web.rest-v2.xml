<?xml version="1.0" encoding="UTF-8"?>
<web-app
	xmlns="http://java.sun.com/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
	version="3.0">

	<display-name>EMM-REST-V2</display-name>

	<context-param>
		<param-name>spring.profiles.active</param-name>
		<param-value>rest</param-value>
	</context-param>

	<listener>
		<listener-class>org.springframework.web.context.request.RequestContextListener</listener-class>
	</listener>

	<!-- Check validity of installation configuration -->
	<listener>
		<listener-class>com.agnitas.emm.core.ConfigurationValidityCheckListener</listener-class>
	</listener>

	<filter>
		<filter-name>cachedBodyFilter</filter-name>
		<filter-class>com.agnitas.emm.restful.v2.infrastructure.security.filter.CachedBodyFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>cachedBodyFilter</filter-name>
		<url-pattern>/rest/v2/*</url-pattern>
	</filter-mapping>
</web-app>
